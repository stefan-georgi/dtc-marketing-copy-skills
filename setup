#!/usr/bin/env bash
set -euo pipefail

# RMBC Skills — Setup
# Symlinks this package into ~/.claude/skills/ so skills resolve automatically.
# Idempotent: safe to run multiple times.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_ROOT="$SCRIPT_DIR"

# Detect package root — handle both repo layouts
# Layout A (main branch): rmbc-skills/skills/, rmbc-skills/bin/
# Layout B (public branch): skills/, bin/ at repo root
if [ ! -d "$PKG_ROOT/skills" ]; then
  echo "Error: skills/ directory not found at $PKG_ROOT"
  echo "Run this script from the package root directory."
  exit 1
fi

# Verify bin/ executables exist
if [ ! -f "$PKG_ROOT/bin/rmbc-update-check" ] || [ ! -f "$PKG_ROOT/bin/rmbc-analytics" ]; then
  echo "Warning: bin/rmbc-update-check or bin/rmbc-analytics not found."
  echo "Some features (update checking, analytics) will not work."
  echo "If you downloaded a zip archive, clone the repo instead for full functionality:"
  echo "  git clone https://github.com/stefan-georgi/dtc-copywriting-skills.git"
  echo ""
fi

TARGET_DIR="$HOME/.claude/skills"
TARGET_NAME="dtc-copywriting-skills"
TARGET_PATH="$TARGET_DIR/$TARGET_NAME"

# Create skills directory if missing
if [ ! -d "$HOME/.claude" ]; then
  echo "Warning: ~/.claude/ does not exist. Creating it."
  echo "Make sure Claude Code is installed."
fi
mkdir -p "$TARGET_DIR"

# Link package root (for bin/, lib/, VERSION resolution)
# Skip if already cloned directly into the target path
if [ "$PKG_ROOT" = "$TARGET_PATH" ]; then
  true  # already in the right place (cloned directly into ~/.claude/skills/)
elif [ -L "$TARGET_PATH" ]; then
  EXISTING="$(readlink "$TARGET_PATH")"
  if [ "$EXISTING" != "$PKG_ROOT" ]; then
    ln -sfn "$PKG_ROOT" "$TARGET_PATH"
  fi
elif [ -e "$TARGET_PATH" ]; then
  echo "Error: $TARGET_PATH exists and is not a symlink."
  echo "If this is a previous copy install, remove it first:"
  echo "  rm -rf $TARGET_PATH"
  echo "Then re-run ./setup"
  exit 1
else
  ln -sfn "$PKG_ROOT" "$TARGET_PATH"
fi

# Link individual skills into ~/.claude/skills/ for auto-discovery
# Claude Code discovers skills at ~/.claude/skills/<name>/SKILL.md
LINKED=0
SKIPPED=0
for SKILL_DIR in "$PKG_ROOT/skills"/*/; do
  [ ! -f "$SKILL_DIR/SKILL.md" ] && continue
  SKILL_NAME="$(basename "$SKILL_DIR")"
  SKILL_LINK="$TARGET_DIR/$SKILL_NAME"
  if [ -L "$SKILL_LINK" ]; then
    EXISTING_SKILL="$(readlink "$SKILL_LINK")"
    if [ "$EXISTING_SKILL" = "$SKILL_DIR" ] || [ "$EXISTING_SKILL" = "${SKILL_DIR%/}" ]; then
      SKIPPED=$((SKIPPED + 1))
      continue
    fi
    ln -sfn "${SKILL_DIR%/}" "$SKILL_LINK"
  elif [ -e "$SKILL_LINK" ]; then
    # Regular file/dir exists with same name — skip to avoid conflicts
    echo "  Skipping $SKILL_NAME — directory already exists (not a symlink)"
    SKIPPED=$((SKIPPED + 1))
    continue
  else
    ln -sfn "${SKILL_DIR%/}" "$SKILL_LINK"
  fi
  LINKED=$((LINKED + 1))
done

# Create state directory with config defaults
STATE_DIR="$HOME/.rmbc-skills"
mkdir -p "$STATE_DIR"
if [ ! -f "$STATE_DIR/config.yaml" ]; then
  cat > "$STATE_DIR/config.yaml" << 'YAML'
analytics_enabled: true
last_update_check: ""
active_product: ""
YAML
fi
# Reset onboarding state so fresh install triggers intro + workspace setup
rm -f "$STATE_DIR/.intro-seen" "$STATE_DIR/.capro-seen" "$STATE_DIR/.telemetry-prompted"
# Clear active product — user picks via /write-copy after install
if command -v sd &>/dev/null; then
  sd -s 'active_product: .*' 'active_product: ""' "$STATE_DIR/config.yaml" 2>/dev/null || true
else
  sed -i'' -e 's/active_product: .*/active_product: ""/' "$STATE_DIR/config.yaml" 2>/dev/null || true
fi

# Hint for non-git downloads
if [ ! -d "$PKG_ROOT/.git" ]; then
  echo ""
  echo "Note: This is a downloaded copy. For automatic updates, clone the repo instead:"
  echo "  git clone https://github.com/stefan-georgi/dtc-copywriting-skills.git"
  echo "  cd dtc-copywriting-skills && ./setup"
fi

# Count skills (canonical only — skip variants and r2 experiments)
SKILL_COUNT=$(find "$PKG_ROOT/skills" -maxdepth 2 -name "SKILL.md" -not -path "*-variant*" -not -path "*-r2-*" -not -path "*-ad1-*" | wc -l | tr -d ' ')
VERSION=$(cat "$PKG_ROOT/VERSION" 2>/dev/null || echo "unknown")

echo ""
echo "RMBC Skills v$VERSION installed ($SKILL_COUNT skills)"
echo "Package: $TARGET_PATH -> $PKG_ROOT"
if [ "$LINKED" -gt 0 ]; then
  echo "Linked $LINKED skills into $TARGET_DIR/"
fi

echo ""
echo "Next: add an RMBC Skills section to your CLAUDE.md (the install prompt handles this)."
