# RMBC Skills — Public Branch .gitignore
# Safety net against accidental inclusion of internal/sensitive files.
# The public branch is an orphan — this protects against bulk copy from main.

# === OS / Editor ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# === Dependencies ===
node_modules/

# === Secrets & Environment ===
.env
.env.*
!.env.example
.envrc
.envrc.md
*.key
*.pem
*.p12
credentials*
secrets*

# === Build Templates & Internal Dev Tools ===
# Main branch uses .tmpl files + gen-skills to produce SKILL.md.
# Only the generated SKILL.md belongs on public.
*.tmpl
templates/
bin/*
!bin/install.mjs
!bin/rmbc-analytics
!bin/rmbc-update-check
!bin/rmbc-upgrade
!bin/rmbc-workspace
lib/*
!lib/rmbc-common.sh
!lib/attribution-variants.md
rmbc-skills/

# === A/B Test Variants ===
# Hypothesis testing creates variant skill dirs on main.
*-variant
*-variant/
*-r2-*/
*-ad1-*/

BENCHMARK_RESULTS.md

# === Eval Pipeline ===
# Programmatic assertion grading, ensemble scoring, pairwise comparison.
grade_*.py
aggregate.py
deepeval*
benchmark*.json
*_eval_*.py
eval-*/
rmbc-skills-ab-test-workspace/

# === Beads / Issue Tracking ===
.beads/
*.jsonl

# === Internal Docs ===
# No docs/ files are tracked on public branch.
docs/

# === Registry Manifests (managed externally) ===
skillfish.json

# === Internal Tooling & Session Artifacts ===
claude-code-plans/
.claude/
AGENTS.md
_notes/
_temp/
.context/
.remember/
.memory/
.loops/
plans/
scripts/
vsl-scripts/

# === Python (eval remnants) ===
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# === Tests ===
tests/

# === Logs & Generated Output ===
*.log
wave*-outputs.md
*-screening-*.md
*-confirmation-*.md

# Dolt database files (added by bd init)
.dolt/
*.db
